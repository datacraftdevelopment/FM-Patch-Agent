{
  "name": "crm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^10.26.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^22.12.0 || ^24.0.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "build": "vite build",
    "build:upload": "pnpm build && pnpm upload",
    "check": "ultracite check",
    "dev": "vite",
    "fix": "ultracite fix",
    "format": "ultracite fix .",
    "lint": "ultracite check .",
    "prepare": "husky",
    "serve": "vite preview",
    "start": "vite",
    "typegen": "pnpx @proofkit/typegen",
    "typegen:ui": "pnpx @proofkit/typegen ui",
    "upload": "node ./scripts/upload.js"
  },
  "dependencies": {
    "@proofkit/fmdapi": "^5.1.1",
    "@proofkit/webviewer": "^3.0.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.10",
    "tw-animate-css": "^1.4.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@proofkit/typegen": "^1.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "open": "^11.0.0",
    "oxlint": "^1.39.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.0.0",
    "vite": "^7.3.3",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm exec ultracite fix"
    ]
  },
  "proofkitMetadata": {
    "initVersion": "2.2.2-beta.0",
    "scaffoldPackage": "@proofkit/cli"
  }
}
